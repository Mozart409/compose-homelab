OPENAI_API_KEY=
OLLAMA_BASE_URL=
TS_AUTH_KEY=

# ProtonVPN WireGuard credentials for Gluetun
# 1. Download WireGuard config from https://account.protonvpn.com/downloads
# 2. Extract PrivateKey from [Interface] section
# 3. Extract Address from [Interface] section (e.g., 10.2.0.2/32)
PROTONVPN_WIREGUARD_PRIVATE_KEY=
PROTONVPN_WIREGUARD_ADDRESSES=
PROTONVPN_SERVER_COUNTRIES=Netherlands

# tsbridge OAuth (from https://login.tailscale.com/admin/settings/oauth)
TS_OAUTH_CLIENT_ID=
TS_OAUTH_CLIENT_SECRET=

OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OPENID_PROVIDER_URL=

ACTUAL_PASSWORD=
ACTUAL_BUDGET_ID=

# Hofvarpnir OIDC Authentication (optional - disabled if HOF_OIDC_ISSUER not set)
# Supports any OIDC-compliant provider: Keycloak, Auth0, Azure AD, Google, Okta, Pocket-ID, etc.
HOF_OIDC_ISSUER=
HOF_OIDC_CLIENT_ID=
HOF_OIDC_CLIENT_SECRET=
HOF_OIDC_SCOPES=openid,profile,email
HOF_OIDC_AUTO_PROVISION=true
HOF_OIDC_REDIRECT_BASE_URL=
HOF_OIDC_LOGOUT_REDIRECT=false
HOF_OIDC_DISCOVERY_TIMEOUT=30
